# env
spp() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)" || root="$(pwd)"
    export PROJ_ROOT="$root"
    echo "[spp] PROJ_ROOT=$PROJ_ROOT"
}
env1() {
    [ -n "$PROJ_ROOT" ] || { echo "[env1] ERROR: run 'spp' first"; return 1; }

    local base="$PROJ_ROOT/src/meta-rity/meta/conf"
    local new="$base/templates/default"

    if [ -d "$new" ]; then
        export TEMPLATECONF="$new"
        echo "[env1] TEMPLATECONF=$TEMPLATECONF"
    elif [ -d "$base" ]; then
        export TEMPLATECONF="$base"
        echo "[env1] TEMPLATECONF=$TEMPLATECONF"
    else
        echo "[env1] ERROR: TEMPLATECONF path not found"
        return 1
    fi
}
env3() {
    [ -n "$PROJ_ROOT" ] || { echo "[env3] ERROR: run 'spp' first"; return 1; }
    export BUILD_DIR="$PROJ_ROOT/build"
    echo "[env3] BUILD_DIR=$BUILD_DIR"
}
env2() {
    [ -n "$PROJ_ROOT" ] || { echo "[env2] ERROR: run 'spp' first"; return 1; }

    local init_script="$PROJ_ROOT/src/poky/oe-init-build-env"
    [ -f "$init_script" ] || { echo "[env2] ERROR: $init_script not found"; return 1; }

    source "$init_script" "$BUILD_DIR"
}
env_mtk700() {
    spp || return 1
    env1 || return 1
    env3 || return 1
    export MACHINE="genio-700-evk"
    echo "[env_mtk700] MACHINE=$MACHINE"
    env2
}
env_mtk720() {
    spp || return 1
    env1 || return 1
    env3 || return 1
    export MACHINE="genio-720-evk"
    echo "[env_mtk720] MACHINE=$MACHINE"
    env2
}
spe700() {
    git branch --show-current 2>/dev/null || true
    env_mtk700
}
spe720() {
    git branch --show-current 2>/dev/null || true
    env_mtk720
}

