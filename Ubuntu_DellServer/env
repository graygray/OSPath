# env
spp() {
    local root
    root="$(git rev-parse --show-toplevel 2>/dev/null)" || root="$(pwd)"
    export PROJ_ROOT="$root"
    echo "[spp] PROJ_ROOT=$PROJ_ROOT"
}
env1() {
    [ -n "$PROJ_ROOT" ] || { echo "[env1] ERROR: run 'spp' first"; return 1; }

    local base="$PROJ_ROOT/src/meta-rity/meta/conf"
    local new="$base/templates/default"

    if [ -d "$new" ]; then
        export TEMPLATECONF="$new"
        echo "[env1] TEMPLATECONF=$TEMPLATECONF"
    elif [ -d "$base" ]; then
        export TEMPLATECONF="$base"
        echo "[env1] TEMPLATECONF=$TEMPLATECONF"
    else
        echo "[env1] ERROR: TEMPLATECONF path not found"
        return 1
    fi
}
env3() {
    [ -n "$PROJ_ROOT" ] || { echo "[env3] ERROR: run 'spp' first"; return 1; }
    export BUILD_DIR="$PROJ_ROOT/build"
    echo "[env3] BUILD_DIR=$BUILD_DIR"
}
env2() {
    [ -n "$PROJ_ROOT" ] || { echo "[env2] ERROR: run 'spp' first"; return 1; }

    local init_script="$PROJ_ROOT/src/poky/oe-init-build-env"
    [ -f "$init_script" ] || { echo "[env2] ERROR: $init_script not found"; return 1; }

    source "$init_script" "$BUILD_DIR"
}
env_mtk700() {
    spp || return 1
    env1 || return 1
    env3 || return 1
    export MACHINE="genio-700-evk"
    echo "[env_mtk700] MACHINE=$MACHINE"
    env2
}
env_mtk720() {
    spp || return 1
    env1 || return 1
    env3 || return 1
    export MACHINE="genio-720-evk"
    echo "[env_mtk720] MACHINE=$MACHINE"
    env2
}
spe700() {
    git branch --show-current 2>/dev/null || true
    env_mtk700
}
spe720() {
    git branch --show-current 2>/dev/null || true
    env_mtk720
}
alias spe='spe700'

primax_recipe_dir() {
    [ -n "$PROJ_ROOT" ] || { echo "[primax] ERROR: PROJ_ROOT is not set"; return 1; }

    local recipe_dir="$PROJ_ROOT/src/meta-primax/recipes-primax/primax"
    [ -d "$recipe_dir" ] || { echo "[primax] INFO: $recipe_dir not found, skip build metadata"; return 1; }

    printf '%s\n' "$recipe_dir"
}
primax_git_dir() {
    [ -n "$PROJ_ROOT" ] || { echo "[primax] ERROR: PROJ_ROOT is not set"; return 1; }

    local candidate
    for candidate in \
        "$PROJ_ROOT" \
        "$PROJ_ROOT/src/meta-primax" \
        "$PROJ_ROOT/src/meta-primax/recipes-primax/primax"
    do
        if [ -d "$candidate" ] && git -C "$candidate" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    echo "[primax] INFO: no git repository found for build metadata" >&2
    return 1
}
primax_misc_dir() {
    local recipe_dir
    recipe_dir="$(primax_recipe_dir)" || return 1

    local misc_dir="$recipe_dir/files/primax-1.0/sysroot/home/root/primax/misc"
    mkdir -p "$misc_dir" || return 1
    printf '%s\n' "$misc_dir"
}
bCommit() {
    local misc_dir
    misc_dir="$(primax_misc_dir)" || return 0

    local git_dir
    git_dir="$(primax_git_dir)" || return 0
    git -C "$git_dir" rev-parse --short=7 HEAD > "$misc_dir/build_commit"
}
bDate() {
    local misc_dir
    misc_dir="$(primax_misc_dir)" || return 0
    date "+%Y%m%d-%H%M" > "$misc_dir/build_date"
}
bBranch() {
    local misc_dir
    misc_dir="$(primax_misc_dir)" || return 0

    local git_dir
    git_dir="$(primax_git_dir)" || return 0
    git -C "$git_dir" branch --show-current > "$misc_dir/build_branch"
}
primax_build_meta() {
    bDate &&
    bCommit &&
    bBranch
}
ytb_machine() {
    [ -n "$MACHINE" ] || { echo "[ytb] ERROR: MACHINE is not set. Run spe700/spe720 or export MACHINE first."; return 1; }
    printf '%s\n' "$MACHINE"
}
ytb_build() {
    local machine
    machine="$(ytb_machine)" || return 1
    primax_build_meta || return 1
    DISTRO=rity-demo MACHINE="$machine" bitbake rity-demo-image
}
ytb_build_clean_primax() {
    local machine
    machine="$(ytb_machine)" || return 1
    primax_build_meta || return 1
    x bb c primax || return 1
    DISTRO=rity-demo MACHINE="$machine" bitbake rity-demo-image
}

